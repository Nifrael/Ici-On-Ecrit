---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const posts = (await getCollection("textes")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Textes">
  <div class="main-title">
    <h3>Textes</h3>
  </div>
  <main>
    <section class="container">
      <ul class="article-list">
        {
          posts.map((post) => (
            <li class="article-card">
              <a href={`/textes/${post.slug}/`}>
                {post.data.heroImage && (
                  <div class="card-image">
                    <Image src={post.data.heroImage} alt="" />
                  </div>
                )}
                <div class="card-content">
                  <h4 class="title">{post.data.title}</h4>
                  <p class="date">
                    {post.data.pubDate.toLocaleDateString("fr-FR", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </p>
                  {post.data.description && (
                    <p class="description">{post.data.description}</p>
                  )}
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>

<style lang="scss">
  @use "@styles/config/variables" as *;
  @use "@styles/config/mixins" as *;

  .main-title {
    margin: 2rem auto;
    width: 90%;
    max-width: 1200px;
    text-align: center;

    @include breakpoint-up($breakpoint-desktop) {
      margin: 4rem auto 3rem auto;
    }

    h3 {
      margin: 0;
      padding: 0.5rem;
      font-size: 2.2rem;
      font-weight: 300;
      letter-spacing: 0.05em;
      color: rgb(var(--black));
      position: relative;
      display: inline-block;

      @include breakpoint-up($breakpoint-desktop) {
        font-size: 2.8rem;
      }

      &::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 40px;
        height: 2px;
        background-color: var(--tertiary-color);
        border-radius: 2px;
        opacity: 0.7;
      }
    }
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    list-style-type: none;
    margin: 3rem 0;
    padding: 0;

    @include breakpoint-up($breakpoint-desktop) {
      gap: 3.5rem;
    }
  }

  .article-card {
    border-radius: 16px;
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.04);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    overflow: hidden;

    @include breakpoint-up($breakpoint-desktop) {
      &:hover {
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
        transform: translateY(-4px);

        .card-image img {
          transform: scale(1.04);
        }

        .title {
          color: var(--tertiary-color);
        }
      }
    }

    a {
      display: flex;
      text-decoration: none;
      color: inherit;
      height: 100%;
    }

    // Default Layout Logic (Mobile First)

    &:first-child {
      a {
        flex-direction: column;
      }
      .card-image {
        width: 100%;
        height: 220px;

        @include breakpoint-up($breakpoint-desktop) {
          height: 380px;
        }
      }

      .card-content {
        @include breakpoint-up($breakpoint-desktop) {
          padding: 3rem;
        }
      }

      .title {
        @include breakpoint-up($breakpoint-desktop) {
          font-size: 2.5rem;
          font-weight: 700;
        }
      }

      .description {
        @include breakpoint-up($breakpoint-desktop) {
          font-size: 1.125rem;
          -webkit-line-clamp: 4;
        }
      }
    }

    &:not(:first-child) {
      a {
        flex-direction: row;
        align-items: stretch;
      }
      .card-image {
        width: 40%;
        height: auto;
        min-height: 160px;

        @include breakpoint-up($breakpoint-desktop) {
          width: 35%;
          min-height: 250px;
        }
      }
      .card-content {
        width: 60%;
        padding: 1.5rem;
        justify-content: center;

        @include breakpoint-up($breakpoint-desktop) {
          width: 65%;
          padding: 2.5rem;
        }
      }
      .title {
        font-size: 1.25rem;
        margin-bottom: 0.4rem;
        font-weight: 600;

        @include breakpoint-up($breakpoint-desktop) {
          font-size: 1.6rem;
          margin-bottom: 0.5rem;
        }
      }
      .date {
        margin-bottom: 0.5rem;
        font-size: 0.75rem;
      }
      .description {
        -webkit-line-clamp: 2;
        font-size: 0.95rem;

        @include breakpoint-up($breakpoint-desktop) {
          font-size: 1.05rem;
        }
      }
    }
  }

  .card-image {
    background-color: #f8f9fa;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: center;
    background: #ffffff;
  }

  .title {
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
    color: rgb(var(--black));
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .date {
    margin: 0 0 1rem 0;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    color: rgb(var(--gray));
  }

  .description {
    margin: 0;
    color: var(--paragraph-color);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
